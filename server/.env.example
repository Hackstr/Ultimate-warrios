# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/tactical_duelist?schema=public"

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (use a strong random secret, min 32 chars: openssl rand -hex 32) ──
JWT_SECRET=your-secret-key-change-in-production

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your-bot-token

# ── Server ──
PORT=3000
NODE_ENV=development

# ── CORS (comma-separated allowed origins) ──
CORS_ORIGIN=https://tacticalduelist.duckdns.org,http://localhost:8080

# ── Blockchain (Solana) ──
BLOCKCHAIN_PROVIDER=solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=
SOLANA_AUTHORITY_KEY=
