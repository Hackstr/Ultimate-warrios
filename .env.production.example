# Production environment variables for docker-compose.production.yml
# Copy to .env.production and fill in real values

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_jwt_secret_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Ports
PORT=3000
WEBGL_PORT=8080
